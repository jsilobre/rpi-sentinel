{
    // Global monitoring settings
    "hysteresis": 2.0,

    // Sensor polling interval (milliseconds)
    "poll_interval_ms": 2000,

    // Web dashboard
    "web_enabled": true,
    "web_port": 8080,

    // MQTT cloud publishing (HiveMQ Cloud or any MQTT broker)
    // Fill in your credentials and set "enabled": true to activate
    "mqtt": {
        "enabled": false,
        "broker_url": "ssl://YOUR_CLUSTER.hivemq.cloud:8883",
        "username": "YOUR_PUBLISHER_USER",
        "password": "YOUR_PUBLISHER_PASSWORD",
        "topic_prefix": "rpi"
    },

    // List of sensors to monitor
    "sensors": [
        {
            // Sensor identifier (used in logs and dashboard)
            "id": "sim-temp",

            // Sensor type: "simulated" or "ds18b20"
            "type": "simulated",

            // Physical quantity being measured
            "metric": "temperature",

            // Warning threshold (must be < threshold_crit)
            "threshold_warn": 50.0,

            // Critical threshold
            "threshold_crit": 65.0
        }
    ]
}
