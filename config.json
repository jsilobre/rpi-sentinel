{
    // Sensor type: "simulated" or "ds18b20"
    "sensor_type": "simulated",

    // Kernel path to the DS18B20 device (used only when sensor_type = "ds18b20")
    "device_path": "/sys/bus/w1/devices/28-000000000000/temperature",

    // Warning threshold (°C) — must be < threshold_crit
    "threshold_warn": 50.0,

    // Critical threshold (°C)
    "threshold_crit": 65.0,

    // Anti-oscillation dead band (°C): a RECOVERED event is only dispatched
    // once the temperature drops below (threshold - hysteresis)
    "hysteresis": 2.0,

    // Sensor polling interval (milliseconds)
    "poll_interval_ms": 2000,

    // Dashboard web
    "web_enabled": true,
    "web_port": 8080
}
