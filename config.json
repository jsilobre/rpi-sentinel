{
    // Type de capteur : "simulated" ou "ds18b20"
    "sensor_type": "simulated",

    // Chemin noyau du DS18B20 (utilisé seulement si sensor_type = "ds18b20")
    "device_path": "/sys/bus/w1/devices/28-000000000000/temperature",

    // Seuil d'avertissement (°C) — doit être < threshold_crit
    "threshold_warn": 50.0,

    // Seuil critique (°C)
    "threshold_crit": 65.0,

    // Zone tampon anti-oscillation (°C) : un événement RECOVERED n'est envoyé
    // que lorsque la température redescend sous (seuil - hysteresis)
    "hysteresis": 2.0,

    // Intervalle de lecture du capteur (millisecondes)
    "poll_interval_ms": 2000
}
