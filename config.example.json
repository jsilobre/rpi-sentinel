{
    // Global monitoring settings
    "hysteresis": 2.0,
    // Sensor polling interval (milliseconds)
    "poll_interval_ms": 2000,
    // Web dashboard
    "web_enabled": true,
    "web_port": 8080,
    // MQTT cloud publishing (HiveMQ Cloud or any MQTT broker)
    // Fill in your credentials and set "enabled": true to activate
    "mqtt": {
        "enabled": false,
        "broker_url": "ssl://YOUR_CLUSTER.hivemq.cloud:8883",
        "username": "YOUR_PUBLISHER_USER",
        "password": "YOUR_PUBLISHER_PASSWORD",
        "topic_prefix": "rpi"
    },
    // Persistent reading history (SQLite). Survives daemon restarts and
    // serves the dashboard hydration via MQTT history-on-demand.
    "history": {
        "enabled": true,
        "db_path": "data/history.db",
        "retention_days": 7,
        "max_points_per_sensor": 50000
    },
    // OTLP export to Grafana Cloud (Mimir for metrics, Loki for threshold logs).
    // The Basic auth header is read from the env var named in 'auth_header_env'
    // (preferred); falls back to literal 'auth_header' for development only.
    "otlp": {
        "enabled": false,
        "endpoint": "https://otlp-gateway-prod-eu-west-2.grafana.net/otlp",
        "auth_header_env": "GRAFANA_CLOUD_OTLP_AUTH",
        "service_instance_id": "rpi-sentinel-1",
        "export_interval_ms": 5000
    },
    // List of sensors to monitor
    "sensors": [
        {
            // Built-in Raspberry Pi SoC temperature (no extra hardware needed).
            // Override "device_path" to target a different thermal zone.
            "id": "cpu-temp",
            "type": "cpu_temp",
            "threshold_warn": 70.0,
            "threshold_crit": 85.0
        },
        {
            "id": "bme280-temp",
            "type": "simulated",
            "metric": "temperature",
            "threshold_warn": 26.0,
            "threshold_crit": 28.0
        },
        {
            "id": "bme280-humidity",
            "type": "simulated",
            "metric": "humidity",
            "threshold_warn": 65.0,
            "threshold_crit": 75.0
        },
        {
            "id": "bme280-pressure",
            "type": "simulated",
            "metric": "pressure",
            "threshold_warn": 1015.0,
            "threshold_crit": 1018.0
        },
        {
            "id": "dht11-temp",
            "type": "simulated",
            "metric": "temperature",
            "threshold_warn": 25.0,
            "threshold_crit": 28.0
        },
        {
            "id": "dht11-humidity",
            "type": "simulated",
            "metric": "humidity",
            "threshold_warn": 68.0,
            "threshold_crit": 78.0
        },
        {
            "id": "hcsr501-motion",
            "type": "simulated",
            "metric": "motion",
            "threshold_warn": 0.5,
            "threshold_crit": 0.9
        }
    ]
}
