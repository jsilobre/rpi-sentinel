{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {"type": "grafana", "uid": "-- Grafana --"},
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Generic dashboard for rpi-sentinel. Sensors auto-discover from the sensor_id label; warn/crit threshold lines overlay each reading via the sensor.threshold.warn / sensor.threshold.crit observable gauges emitted by the daemon. No code change needed when sensors are added or removed in config.json.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "panels": [],
      "title": "Live readings — $sensor_id",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Latest sensor value with warn/crit threshold lines overlaid.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "axisLabel": "",
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": true
          },
          "mappings": [],
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]},
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {"id": "byFrameRefID", "options": "warn"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}},
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
              {"id": "custom.lineWidth", "value": 1},
              {"id": "custom.fillOpacity", "value": 0}
            ]
          },
          {
            "matcher": {"id": "byFrameRefID", "options": "crit"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}},
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}},
              {"id": "custom.lineWidth", "value": 1},
              {"id": "custom.fillOpacity", "value": 0}
            ]
          }
        ]
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "legend": {"calcs": ["last", "min", "max"], "displayMode": "table", "placement": "bottom"},
        "tooltip": {"mode": "multi", "sort": "none"}
      },
      "repeat": "sensor_id",
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sensor_reading{sensor_id=\"$sensor_id\"}",
          "legendFormat": "{{metric}}",
          "range": true,
          "refId": "reading"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sensor_threshold_warn{sensor_id=\"$sensor_id\"}",
          "legendFormat": "warn",
          "range": true,
          "refId": "warn"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "editorMode": "code",
          "expr": "sensor_threshold_crit{sensor_id=\"$sensor_id\"}",
          "legendFormat": "crit",
          "range": true,
          "refId": "crit"
        }
      ],
      "title": "$sensor_id",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 10},
      "id": 200,
      "panels": [],
      "title": "Threshold events (Loki)",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
      "description": "All threshold breach and recovery events emitted by the daemon. Filter via the $sensor_id variable.",
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 11},
      "id": 2,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${DS_LOKI}"},
          "editorMode": "code",
          "expr": "{service_name=\"rpi-sentinel\"} | event_type =~ \"threshold_.*\" | sensor_id =~ \"${sensor_id:regex}\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Threshold breach / recovery",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["rpi-sentinel", "generic"],
  "templating": {
    "list": [
      {
        "current": {"selected": false, "text": "All", "value": "$__all"},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(sensor_reading, sensor_id)",
        "hide": 0,
        "includeAll": true,
        "label": "Sensor",
        "multi": true,
        "name": "sensor_id",
        "options": [],
        "query": {"query": "label_values(sensor_reading, sensor_id)", "refId": "PrometheusVariableQueryEditor-VariableQuery"},
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "rpi-sentinel",
  "uid": "rpi-sentinel-generic",
  "version": 1,
  "weekStart": "",
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Mimir / Prometheus datasource fed by OTLP metrics from the daemon",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    },
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki datasource fed by OTLP logs from the daemon",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "datasource", "id": "loki", "name": "Loki", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "logs", "name": "Logs", "version": ""}
  ]
}
